{
  "name": "@kwooshung/react-overlay-scrollbars-smooth",
  "version": "1.0.3",
  "title": "React Overlay Scrollbars Smooth",
  "description": "A React scrollbar custom component that hides the native scroll bar, provides a custom style overlay scroll bar, and retains the native functionality and feel while having scrolling inertia.",
  "private": false,
  "tags": [
    "kwooshung",
    "react",
    "github-page",
    "github",
    "pages",
    "page",
    "react-component"
  ],
  "keywords": [
    "kwooshung",
    "react",
    "github-page",
    "github",
    "pages",
    "page",
    "react-component"
  ],
  "author": "kwooshung (https://github.com/kwooshung)",
  "homepage": "https://github.com/kwooshung/react-overlay-scrollbars-smooth",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwooshung/react-overlay-scrollbars-smooth.git"
  },
  "bugs": {
    "url": "https://github.com/kwooshung/react-overlay-scrollbars-smooth/issues"
  },
  "browser": "lib/github-pages.min.js",
  "main": "lib/github-pages.js",
  "module": "lib/github-pages.esm.js",
  "types": "typesgithub-pages.d.ts",
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "build": "tsc && vite build",
    "stylelint": "stylelint --fix --cache --quiet --max-warnings 0 --config .stylelintrc.cjs \"**/*.{css,less,scss,sass,stylus,styl}\"",
    "eslint": "eslint . --fix --cache --quiet --report-unused-disable-directives --max-warnings 0 --ext .js,.cjs,.jsx,.ts,.cts,.tsx",
    "preview": "vite preview",
    "test": "jest --verbose",
    "test:watch": "jest --verbose --watch",
    "test:ci": "jest --ci",
    "commit": "pnpm changelog && git add . && cz-customizable",
    "changelog": "conventional-changelog -i CHANGELOG.md -s -r 0 && node plugin-customizable.cjs",
    "release": "standard-version-helper -cmd pnpm changelog"
  },
  "config": {
    "cz-customizable": {
      "config": "./.cz-config.cjs"
    },
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "standard-version": {
    "skip": {
      "changelog": true
    }
  },
  "dependencies": {
    "@arco-design/web-react": "^2.55.0",
    "detect-indent": "^7.0.1",
    "ora": "^7.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "readline-sync": "^1.4.10",
    "semver": "^7.5.4"
  },
  "peerDependencies": {
    "react": ">=16.6.0",
    "react-dom": ">=16.6.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^18.1.0",
    "@kwooshung/standard-version-helper": "^1.2.3",
    "@swc/core": "^1.3.95",
    "@swc/jest": "^0.2.29",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/readline-sync": "^1.4.6",
    "@types/semver": "^7.5.4",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "commitizen": "^4.3.0",
    "commitlint": "^18.2.0",
    "commitlint-config-cz": "^0.13.3",
    "commitlint-config-git-commit-emoji": "^1.0.0",
    "conventional-changelog": "^5.1.0",
    "conventional-changelog-cli": "^4.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.0.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.2",
    "postcss-less": "^6.0.0",
    "prettier": "^3.0.3",
    "standard-version": "^9.5.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-order": "^6.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-imp": "^2.4.0"
  },
  "license": "MIT"
}
